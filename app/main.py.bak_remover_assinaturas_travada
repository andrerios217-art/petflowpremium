    busca: str | None = _VectorPetQuery(None),
    status: str | None = _VectorPetQuery(None),
    db: _VectorPetSession = _VectorPetDepends(_VectorPetGetDb),
):
    query = db.query(_VectorPetAssinaturaPet)

    if status:
        query = query.filter(_VectorPetAssinaturaPet.status == status)

    assinaturas = query.order_by(_VectorPetAssinaturaPet.id.desc()).limit(300).all()

    dados = []

    for assinatura in assinaturas:
        cliente = db.query(_VectorPetCliente).filter(_VectorPetCliente.id == assinatura.cliente_id).first()
        pet = db.query(_VectorPetPet).filter(_VectorPetPet.id == assinatura.pet_id).first()

        item = {
            "assinatura": assinatura,
            "cliente_nome": getattr(cliente, "nome", "") if cliente else "",
            "pet_nome": getattr(pet, "nome", "") if pet else "",
        }

        dados.append(item)

    if busca:
        termo = busca.strip().lower()

        dados = [
            item for item in dados
            if termo in str(item["assinatura"].id).lower()
            or termo in (item["cliente_nome"] or "").lower()
            or termo in (item["pet_nome"] or "").lower()
        ]

    total = len(dados)
    ativas = len([item for item in dados if getattr(item["assinatura"], "status", "") == "ATIVA"])
    canceladas = len([item for item in dados if getattr(item["assinatura"], "status", "") == "CANCELADA"])
    valor_ativo = sum(
        _vp_decimal(getattr(item["assinatura"], "valor_final", 0))
        for item in dados
        if getattr(item["assinatura"], "status", "") == "ATIVA"
    )

    linhas = ""

    if dados:
        linhas = "\n".join([_vp_assinatura_linha(db, item["assinatura"]) for item in dados])
    else:
        linhas = '<tr><td colspan="8">Nenhuma assinatura encontrada.</td></tr>'

    busca_value = _VectorPetEscape(busca or "")

    status_options = {
        "": "Todos",
        "ATIVA": "Ativas",
        "PAUSADA": "Pausadas",
        "CANCELADA": "Canceladas",
        "ENCERRADA": "Encerradas",
    }

    options_html = ""

    for valor, label in status_options.items():
        selected = "selected" if (status or "") == valor else ""
        options_html += f'<option value="{valor}" {selected}>{label}</option>'

    html = f"""
