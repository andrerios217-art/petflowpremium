@app.post("/assinaturas-admin/cancelar/{assinatura_id}")
async def vectorpet_assinaturas_admin_cancelar(
    assinatura_id: int,
    db: _VectorPetSession = _VectorPetDepends(_VectorPetGetDb),
):
    assinatura = (
        db.query(_VectorPetAssinaturaPet)
        .filter(_VectorPetAssinaturaPet.id == assinatura_id)
        .first()
    )

    if assinatura is not None:
        assinatura.status = "CANCELADA"

        if hasattr(assinatura, "data_cancelamento"):
            assinatura.data_cancelamento = _VectorPetDate.today()

        db.add(assinatura)
        db.commit()

    return _VectorPetRedirectResponse("/assinaturas", status_code=303)
