def _vp_moeda(valor):
    try:
        valor = float(valor or 0)
    except Exception:
        valor = 0

    texto = f"{valor:,.2f}"
    texto = texto.replace(",", "X").replace(".", ",").replace("X", ".")
    return "R$ " + texto


def _vp_data(valor):
    if not valor:
        return "-"

    try:
        return valor.strftime("%d/%m/%Y")
    except Exception:
        return str(valor)


def _vp_decimal(valor):
    if valor is None:
        return 0.0

    if isinstance(valor, _VectorPetDecimal):
        return float(valor)

    try:
        return float(valor)
    except Exception:
        return 0.0


def _vp_assinatura_linha(db: _VectorPetSession, assinatura: _VectorPetAssinaturaPet):
    cliente = db.query(_VectorPetCliente).filter(_VectorPetCliente.id == assinatura.cliente_id).first()
    pet = db.query(_VectorPetPet).filter(_VectorPetPet.id == assinatura.pet_id).first()

    cliente_nome = _VectorPetEscape(getattr(cliente, "nome", "") or "-")
    pet_nome = _VectorPetEscape(getattr(pet, "nome", "") or "-")
    status = _VectorPetEscape(getattr(assinatura, "status", "") or "-")

    status_classe = "assinaturas-status-outra"

    if status == "ATIVA":
        status_classe = "assinaturas-status-ativa"

    if status == "CANCELADA":
        status_classe = "assinaturas-status-cancelada"

    botao_cancelar = ""

    if status not in ["CANCELADA", "ENCERRADA"]:
        botao_cancelar = f"""
          <form method="post" action="/assinaturas-admin/cancelar/{assinatura.id}" onsubmit="return confirm('Deseja cancelar esta assinatura?');">
            <button class="assinaturas-btn assinaturas-btn-danger" type="submit">Cancelar</button>
          </form>
        """

    return f"""
      <tr>
        <td>#{assinatura.id}</td>
        <td>{cliente_nome}</td>
        <td>{pet_nome}</td>
        <td>{_vp_data(getattr(assinatura, "data_inicio", None))}</td>
        <td>{_vp_data(getattr(assinatura, "data_fim", None))}</td>
        <td><span class="assinaturas-status {status_classe}">{status}</span></td>
        <td>{_vp_moeda(getattr(assinatura, "valor_final", 0))}</td>
        <td>
          <div class="assinaturas-acoes">
            <a class="assinaturas-btn assinaturas-btn-soft" href="/assinaturas/editar/{assinatura.id}">Editar</a>
            {botao_cancelar}
          </div>
        </td>
      </tr>
    """


